# @llmnative/react showcase — Environment Variables
# Copy this file to .env and fill in the values you need.
# All variables are optional unless you're using that specific provider.

# --- Core ---
VITE_DATA_PROVIDER=firebase
VITE_ICON_PROVIDER=lucide
VITE_THEME_PROVIDER=default

# --- Proxy (required for AI calls from the browser) ---
# Set VITE_PROXY_PROVIDER=viteDevProxy and VITE_PROXY_ENABLED=true
# to route cross-origin AI requests through the Vite dev server.
VITE_PROXY_PROVIDER=none
VITE_PROXY_ENABLED=false

# --- Firebase ---
VITE_FIREBASE_APIKEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Google OAuth ---
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_SCOPE=

# --- Supabase ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Dropbox ---
VITE_DROPBOX_CLIENT_ID=
VITE_DROPBOX_ROOT_PATH=

# --- AI providers ---
VITE_OPENAI_API_KEY=
VITE_OPENROUTER_API_KEY=
VITE_OPENCODE_API_KEY=
VITE_GEMINI_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_DEEPSEEK_API_KEY=
VITE_MISTRAL_API_KEY=

# --- OpenAI-compatible (leave BASE_URL empty to disable) ---
VITE_OPENAI_COMPATIBLE_BASE_URL=
VITE_OPENAI_COMPATIBLE_API_KEY=
