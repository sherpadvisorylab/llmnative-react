{
  "name": "@llmnative/react",
  "version": "0.1.2",
  "description": "LLM-native React framework for deterministic UI generation. Data-driven by default, schema-driven optional. Ultra-low token consumption — built for AI agents, not just humans.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/types/src/index.d.ts",
  "style": "dist/index.css",
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./vite": "./dist/vite.mjs",
    "./dist/index.css": "./dist/index.css"
  },
  "scripts": {
    "prebuild": "node scripts/dev/build-local.js --restore-only",
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:dev": "vite build --mode development && tsc --emitDeclarationOnly",
    "watch:dev": "vite build --watch",
    "build:local": "node scripts/dev/build-local.js",
    "prepublishOnly": "npm run build",
    "updateReadme": "node scripts/dev/updateReadme.js",
    "test": "vitest run",
    "test:e2e:proxy-scaffold": "node scripts/e2e/test-proxy-scaffold.js",
    "test:e2e:proxy-runtime": "vitest run tests/e2e/proxy-runtime.test.ts --environment node",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "bin": {
    "llmnative": "bin/cli.js"
  },
  "files": [
    "dist",
    "dist/**/*.map",
    "bin",
    "scripts/cli",
    "themes"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sherpadvisorylab/llmnative-react.git"
  },
  "keywords": [
    "react",
    "admin",
    "dashboard",
    "crud",
    "schema-driven",
    "admin-panel",
    "backoffice",
    "internal-tools",
    "ai-first",
    "ai-assisted",
    "provider-agnostic",
    "framework",
    "typescript",
    "tailwind",
    "vite"
  ],
  "author": "wolfgan",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/sherpadvisorylab/llmnative-react/issues"
  },
  "homepage": "https://github.com/sherpadvisorylab/llmnative-react#readme",
  "peerDependencies": {
    "@phosphor-icons/react": "^2.0.0",
    "@supabase/supabase-js": "^2.107.0",
    "firebase": "^10.14.0",
    "lucide-react": "^0.400.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "peerDependenciesMeta": {
    "@phosphor-icons/react": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.25.7",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/preset-env": "^7.25.7",
    "@babel/preset-react": "^7.25.7",
    "@babel/preset-typescript": "^7.25.7",
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/supabase-js": "^2.107.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/papaparse": "^5.3.16",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitest/coverage-v8": "2.1",
    "autoprefixer": "^10.5.0",
    "googleapis": "^171.4.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.14.0",
    "postcss": "^8.5.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.30.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.2",
    "vite": "^5.4.21",
    "vitest": "2.1"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-liquid": "^6.3.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@tiptap/extension-character-count": "^3.26.1",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/extension-table": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "liquidjs": "^10.27.0",
    "papaparse": "^5.5.3",
    "prismjs": "^ 1.30.0",
    "react-markdown": "^10.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tui-image-editor": "^3.15.3"
  }
}
