{
  "name": "react-firestrap",
  "version": "1.5.8",
  "description": "React FireStrap is a powerful framework that accelerates the creation of interactive user interfaces. Built with React and Bootstrap, it features native authentication support and smooth integration with services like Firebase, Dropbox, and messaging systems. Developers are free to implement any Bootstrap theme, allowing for endless customization possibilities. With React FireStrap, you can effortlessly design dynamic layouts and customize templates with modular components, making it the ultimate toolkit for efficiently building responsive and engaging applications.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "style": "dist/index.css",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "scripts": {
    "prebuild": "node scripts/dev/build-local.js --restore-only",
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:dev": "vite build --mode development && tsc --emitDeclarationOnly",
    "watch:dev": "vite build --watch",
    "build:webpack": "webpack --mode production",
    "build:webpack:dev": "webpack --mode development",
    "build:local": "node scripts/dev/build-local.js",
    "prepublishOnly": "npm run build",
    "updateReadme": "node scripts/dev/updateReadme.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "bin": {
    "react-firestrap": "./bin/cli.js"
  },
  "files": [
    "dist",
    "dist/**/*.map",
    "bin",
    "scripts/cli",
    "themes"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sherpadvisorylab/react-quicksuite.git"
  },
  "keywords": [
    "react",
    "reactjs",
    "ui",
    "user-interface",
    "component-library",
    "react-components",
    "modular",
    "integration",
    "responsive",
    "bootstrap",
    "framework",
    "interactive",
    "firebase",
    "dropbox",
    "npm",
    "development",
    "template",
    "admin",
    "react-admin",
    "uiadmin",
    "ui-admin"
  ],
  "author": "wolfgan",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/sherpadvisorylab/react-quicksuite/issues"
  },
  "homepage": "https://github.com/sherpadvisorylab/react-quicksuite#readme",
  "peerDependencies": {
    "@phosphor-icons/react": "^2.0.0",
    "firebase": "^10.14.0",
    "lucide-react": "^0.400.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "peerDependenciesMeta": {
    "@phosphor-icons/react": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.25.7",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/preset-env": "^7.25.7",
    "@babel/preset-react": "^7.25.7",
    "@babel/preset-typescript": "^7.25.7",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/papaparse": "^5.3.16",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitest/coverage-v8": "2.1",
    "autoprefixer": "^10.5.0",
    "babel-loader": "^9.2.1",
    "css-loader": "^7.1.4",
    "googleapis": "^171.4.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.14.0",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss": "^8.5.14",
    "postcss-loader": "^8.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.30.3",
    "tailwindcss": "^4.2.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.21",
    "vitest": "2.1",
    "webpack": "^5.99.5",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "papaparse": "^5.5.3",
    "prismjs": "^ 1.30.0",
    "react-markdown": "^10.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tui-image-editor": "^3.15.3"
  }
}
